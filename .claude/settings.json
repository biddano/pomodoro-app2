{
    "permissions": {
        "allow": [
            "Skill(update-config)",
            "Skill(update-config:*)",
            "Bash(pwsh -Command '$input = [Console]::In.ReadToEnd\\(\\) | ConvertFrom-Json; $filePath = $input.tool_input.file_path; if \\($filePath\\) { Write-Host \"File path: $filePath\" }')",
            "Bash(npx prettier-csharp *)",
            "Bash(node .claude/format-cs.js docs/TestRunner.cs)",
            "Bash(node *)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx prettier-csharp --write \"${filePath}\""
                    }
                ]
            },
            {
                "matcher": "Read|Write|Edit",
                "hooks": [
                  {
                    "type": "command",
                    "command": "printf \"%s\\n%s\\n\" \"$(date '+%Y-%m-%d %H:%M:%S')\" \"$(jq '.')\" >> ./docs/tools.log 2>/dev/null || true"
                  }
                ]
              }
        ]
    }
}